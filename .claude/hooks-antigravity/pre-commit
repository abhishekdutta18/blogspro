#!/bin/bash
# =============================================================================
# ECC Pre-Commit Hook (Antigravity-Native)
# Rebuilt from everything-claude-code hooks for non-Claude-Code environments.
# =============================================================================
# Checks:
# 1. Secret Detection — blocks commits containing API keys
# 2. Console.log Warning — warns about console.log in staged JS/TS files
# 3. Config Protection — warns if linter/formatter configs are being modified
# 4. No --no-verify — reminder if user bypassed hooks recently
# =============================================================================

RED='\033[0;31m'
YELLOW='\033[0;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
BOLD='\033[1m'

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null)
ERRORS=0
WARNINGS=0

echo -e "${CYAN}${BOLD}🛡️  ECC Pre-Commit Guard${NC}"
echo ""

# --- 1. SECRET DETECTION ---
echo -e "${CYAN}[1/4] Scanning for secrets...${NC}"

SECRET_PATTERNS=(
  'sk-[a-zA-Z0-9]{20,}'           # OpenAI / Anthropic keys
  'ghp_[a-zA-Z0-9]{36}'           # GitHub PAT
  'ghs_[a-zA-Z0-9]{36}'           # GitHub App token
  'AKIA[0-9A-Z]{16}'              # AWS Access Key
  're_[a-zA-Z0-9]{20,}'           # Resend API key
  'sntrys_[a-zA-Z0-9]{20,}'       # Sentry auth token
  'xoxb-[0-9]{10,}'               # Slack Bot token
  'xoxp-[0-9]{10,}'               # Slack User token
  'AIza[0-9A-Za-z_-]{35}'         # Google API key
  'sk_live_[a-zA-Z0-9]{24,}'      # Stripe live key
  'pk_live_[a-zA-Z0-9]{24,}'      # Stripe publishable key
  'SG\.[a-zA-Z0-9_-]{22}\.'       # SendGrid key
  'eyJ[a-zA-Z0-9_-]*\.eyJ'        # JWT token (base64 header.payload)
)

for file in $STAGED_FILES; do
  # Skip binary files, lock files, and .env.example
  if [[ "$file" =~ \.(png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|pdf|zip)$ ]]; then continue; fi
  if [[ "$file" =~ (package-lock|yarn\.lock|pnpm-lock) ]]; then continue; fi
  if [[ "$file" == ".env.example" ]]; then continue; fi

  for pattern in "${SECRET_PATTERNS[@]}"; do
    matches=$(git diff --cached "$file" 2>/dev/null | grep -E "^\+" | grep -oE "$pattern" 2>/dev/null)
    if [ -n "$matches" ]; then
      echo -e "  ${RED}✗ SECRET DETECTED in ${file}:${NC}"
      echo -e "    ${RED}Pattern: $pattern${NC}"
      echo -e "    ${RED}Match: ${matches:0:20}...${NC}"
      ERRORS=$((ERRORS + 1))
    fi
  done
done

if [ $ERRORS -eq 0 ]; then
  echo -e "  ${GREEN}✓ No secrets found${NC}"
fi

# --- 2. CONSOLE.LOG CHECK ---
echo -e "${CYAN}[2/4] Checking for console.log...${NC}"

JS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(js|ts|jsx|tsx|mjs)$' || true)
CONSOLE_COUNT=0

for file in $JS_FILES; do
  # Skip test files and config files
  if [[ "$file" =~ (test|spec|__tests__|\.config\.) ]]; then continue; fi
  if [[ "$file" =~ node_modules ]]; then continue; fi

  count=$(git diff --cached "$file" 2>/dev/null | grep -E "^\+.*console\.(log|debug|info)\(" | wc -l | tr -d ' ')
  if [ "$count" -gt 0 ]; then
    echo -e "  ${YELLOW}⚠ console.log found in ${file} (${count} new)${NC}"
    CONSOLE_COUNT=$((CONSOLE_COUNT + count))
    WARNINGS=$((WARNINGS + 1))
  fi
done

if [ $CONSOLE_COUNT -eq 0 ]; then
  echo -e "  ${GREEN}✓ No console.log statements${NC}"
else
  echo -e "  ${YELLOW}  Total: ${CONSOLE_COUNT} console statements (warning only)${NC}"
fi

# --- 3. CONFIG PROTECTION ---
echo -e "${CYAN}[3/4] Checking config protection...${NC}"

PROTECTED_CONFIGS=(
  ".eslintrc" ".eslintrc.js" ".eslintrc.json" "eslint.config.js" "eslint.config.mjs"
  ".prettierrc" ".prettierrc.js" "prettier.config.js"
  "tsconfig.json" "tsconfig.build.json"
  "biome.json" "biome.jsonc"
)

CONFIG_WARNINGS=0
for file in $STAGED_FILES; do
  basename=$(basename "$file")
  for protected in "${PROTECTED_CONFIGS[@]}"; do
    if [ "$basename" = "$protected" ]; then
      echo -e "  ${YELLOW}⚠ Config modified: ${file} — fix code, don't weaken config${NC}"
      CONFIG_WARNINGS=$((CONFIG_WARNINGS + 1))
      WARNINGS=$((WARNINGS + 1))
    fi
  done
done

if [ $CONFIG_WARNINGS -eq 0 ]; then
  echo -e "  ${GREEN}✓ No protected configs modified${NC}"
fi

# --- 4. COMMIT QUALITY ---
echo -e "${CYAN}[4/4] Commit quality check...${NC}"

STAGED_COUNT=$(echo "$STAGED_FILES" | grep -c . 2>/dev/null || echo "0")
if [ "$STAGED_COUNT" -gt 20 ]; then
  echo -e "  ${YELLOW}⚠ Large commit: ${STAGED_COUNT} files staged. Consider splitting.${NC}"
  WARNINGS=$((WARNINGS + 1))
else
  echo -e "  ${GREEN}✓ Commit size OK (${STAGED_COUNT} files)${NC}"
fi

# --- SUMMARY ---
echo ""
if [ $ERRORS -gt 0 ]; then
  echo -e "${RED}${BOLD}✗ BLOCKED: ${ERRORS} secret(s) detected. Remove them before committing.${NC}"
  echo -e "${RED}  Use 'git diff --cached' to review staged changes.${NC}"
  exit 1
elif [ $WARNINGS -gt 0 ]; then
  echo -e "${YELLOW}${BOLD}⚠ ${WARNINGS} warning(s). Commit proceeding.${NC}"
  exit 0
else
  echo -e "${GREEN}${BOLD}✓ All checks passed.${NC}"
  exit 0
fi
