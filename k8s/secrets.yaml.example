apiVersion: v1
kind: Secret
metadata:
  name: blogspro-secrets
  namespace: blogspro
type: Opaque
stringData:
  # Institutional AI Keys
  GROQ_API_KEY: "REPLACE_WITH_KEY"
  GEMINI_API_KEY: "REPLACE_WITH_KEY"
  SAMBANOVA_API_KEY: "REPLACE_WITH_KEY"
  CEREBRAS_API_KEY: "REPLACE_WITH_KEY"
  
  # Sovereign Storage & Auth (GCP/Firebase)
  FIREBASE_PROJECT_ID: "blogspro-ai"
  FIREBASE_CLIENT_EMAIL: "REPLACE_WITH_EMAIL"
  FIREBASE_PRIVATE_KEY: |
    -----BEGIN PRIVATE KEY-----
    REPLACE_WITH_PRIVATE_KEY
    -----END PRIVATE KEY-----
    
  # GitHub Synchronization
  GITHUB_TOKEN: "REPLACE_WITH_TOKEN"
  
  # Market Intelligence Fallbacks
  UPSTOX_API_KEY: "REPLACE_WITH_KEY"
  UPSTOX_API_SECRET: "REPLACE_WITH_KEY"
