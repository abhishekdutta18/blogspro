rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ───────────────────────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }

    function currentUserRole() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return currentUserRole() == 'admin';
    }

    function isContributor() {
      return currentUserRole() == 'editor' || currentUserRole() == 'coauthor';
    }

    function canSelfAssignRequestedRole(role) {
      return role == 'reader' || role == 'editor' || role == 'coauthor';
    }

    function postFieldsAreSafe() {
      return request.resource.data.keys().hasOnly([
        'title', 'excerpt', 'content', 'category', 'slug',
        'published', 'authorUid', 'authorName', 'authorEmail',
        'createdAt', 'updatedAt', 'premium', 'views'
      ]);
    }

    function contributorCanCreateOwnPost() {
      return isContributor()
        && postFieldsAreSafe()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && (!request.resource.data.keys().hasAny(['premium']) || request.resource.data.premium == false)
        && (!request.resource.data.keys().hasAny(['views']) || request.resource.data.views == 0)
        && (
          currentUserRole() == 'coauthor'
            ? request.resource.data.published is bool
            : request.resource.data.published == false
        );
    }

    function contributorCanUpdateOwnPost() {
      return isContributor()
        && resource.data.authorUid == request.auth.uid
        && postFieldsAreSafe()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && (!resource.data.keys().hasAny(['premium']) || request.resource.data.premium == resource.data.premium)
        && (!resource.data.keys().hasAny(['views']) || request.resource.data.views == resource.data.views)
        && (
          currentUserRole() == 'coauthor'
            ? request.resource.data.published is bool
            : request.resource.data.published == false
        );
    }

    // ── POSTS ──────────────────────────────────────────────────────────────
    match /posts/{postId} {
      // Published posts are queryable in collection views. Drafts stay limited
      // to admins and each author's own posts.
      allow list: if resource.data.published == true
                  || isAdmin()
                  || (signedIn() && resource.data.authorUid == request.auth.uid);

      // Get (single doc): free posts open to all; premium requires sign-in.
      allow get:  if (resource.data.published == true && (resource.data.premium != true || signedIn()))
                  || isAdmin()
                  || (signedIn() && resource.data.authorUid == request.auth.uid);

      // Admin can manage all posts. Admin-assigned contributors can create and
      // update only their own posts, without touching premium/views metadata.
      // Exception: anyone can increment ONLY the 'views' field (for view tracking).
      allow create: if isAdmin() || contributorCanCreateOwnPost();
      allow delete: if isAdmin();
      allow update: if isAdmin()
                    || contributorCanUpdateOwnPost()
                    || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])
                        && request.resource.data.views == resource.data.views + 1);
    }

    // ── COMMENTS (subcollection of posts) ──────────────────────────────────
    match /posts/{postId}/comments/{commentId} {
      // Anyone can read comments.
      allow read: if true;

      // Any logged-in user can post a comment, with strict field validation.
      // createdAt must be the server timestamp — prevents backdating/spoofing.
      allow create: if request.auth != null
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 2
                    && request.resource.data.text.size() < 1000
                    && request.resource.data.authorUid == request.auth.uid
                    && request.resource.data.createdAt == request.time;

      // Only admin can delete comments.
      allow delete: if isAdmin();

      // Comments are immutable once posted.
      allow update: if false;
    }

    // ── USERS ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Users can only read their own profile. Admins can read all profiles.
      allow read: if request.auth.uid == userId || isAdmin();

      // User can create their own document on registration, but cannot self-assign
      // elevated access. Any contributor role request is stored separately.
      allow create: if request.auth.uid == userId
                    && request.resource.data.keys().hasOnly([
                      'uid', 'name', 'email', 'bio', 'photoURL',
                      'role', 'requestedRole', 'createdAt'
                    ])
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.role == 'reader'
                    && (!request.resource.data.keys().hasAny(['requestedRole'])
                        || canSelfAssignRequestedRole(request.resource.data.requestedRole))
                    && request.resource.data.createdAt == request.time;

      // User can update their own profile and request a role change by updating
      // requestedRole, but can never self-change role/uid/createdAt.
      // Admin can update any user document (including role changes).
      allow update: if (request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                      'name', 'email', 'bio', 'photoURL',
                      'requestedRole', 'updatedAt', 'roleRequestUpdatedAt'
                    ])
                    && request.resource.data.uid == resource.data.uid
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.createdAt == resource.data.createdAt
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['requestedRole'])
                        || canSelfAssignRequestedRole(request.resource.data.requestedRole)))
                    || isAdmin();

      // User can delete their own account.
      allow delete: if request.auth.uid == userId || isAdmin();
    }

    // ── SUBSCRIBERS (newsletter) ────────────────────────────────────────────
    match /subscribers/{subId} {
      // Anyone can subscribe (no login required).
      // Email must pass a basic format check and have a reasonable length.
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.matches('.*@.*\\..*')
                    && request.resource.data.email.size() > 5
                    && request.resource.data.email.size() < 255;

      // Only admin can view, edit, or delete subscribers.
      allow read, update, delete: if isAdmin();
    }

    // ── AI MEMORY (#18, #19, #28) ───────────────────────────────────────────
    match /ai_memory/{docId} {
      // Only admin can read and write AI memory patterns.
      allow read, write: if isAdmin();
    }

    // ── SITE SETTINGS / PUBLIC SITE META ─────────────────────────────────────
    match /site/{docId} {
      // Public pages can read site settings/meta (about, feature toggles).
      allow read: if true;
      // Only admin can update site-level settings.
      allow write: if isAdmin();
    }

  }
}
